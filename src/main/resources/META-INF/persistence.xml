<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="u4-w3-d3">
        <class>lafdilibilal.entities.Persona</class>
        <class>lafdilibilal.entities.Partecipazione</class>
        <class>lafdilibilal.entities.evento</class>
        <class>lafdilibilal.entities.Location</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/u4-w3-d3"/>
            <!-- Nel mio caso la porta è 5433 nel vostro sarà 5432 (ovviamente se non l'avete cambiata) -->
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- Quest'impostazione serve per far creare/aggiornare automaticamente le tabelle all'avvio dell'applicazione -->
        </properties>
    </persistence-unit>
</persistence>